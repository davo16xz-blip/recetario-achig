<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Recetario de Gabriel Achig</title>
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&family=DM+Serif+Display:ital@0;1&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root{
  --cream:#f8f1e2; --paper:#fdfaf2; --line:#e0d0b0;
  --ink:#1c1508;   --faded:#9a8060;
  --red:#b83030;   --teal:#1a7a65;  --amber:#c47820;
  --gold:#e8c870;  --cover:#6e2608; --spine:#4a1604;
  --violet:#6b3fa0;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}

body{
background: radial-gradient(ellipse at 50% 35%, #2e1e0e 0%, #0e0804 100%);
min-height:100vh;
display:flex;flex-direction:column;align-items:center;justify-content:center;
overflow:hidden;
font-family:‘Caveat’,cursive;
-webkit-user-select:none;user-select:none;
}

.site-title{
font-family:‘DM Serif Display’,serif;font-style:italic;
color:var(–gold);font-size:clamp(.95rem,2.2vw,1.4rem);
letter-spacing:4px;margin-bottom:12px;
text-shadow:0 0 30px rgba(232,200,112,.5);
animation:glow 3s ease-in-out infinite alternate;
}
@keyframes glow{
from{text-shadow:0 0 12px rgba(232,200,112,.3);}
to  {text-shadow:0 0 32px rgba(232,200,112,.8);}
}

.lang-bar{
display:flex;background:rgba(255,255,255,.06);
border:1px solid rgba(232,200,112,.22);border-radius:30px;
padding:3px;margin-bottom:16px;
}
.lang-btn{
font-family:‘Caveat’,cursive;font-size:.9rem;padding:5px 20px;
border:none;background:transparent;color:rgba(232,200,112,.4);
border-radius:26px;cursor:pointer;transition:all .3s;
}
.lang-btn.active{background:var(–gold);color:var(–ink);font-weight:700;}

.book-scene{
perspective:2400px;
width:min(96vw,860px);
height:min(74vh,530px);
position:relative;
}
.book{
width:100%;height:100%;
position:relative;transform-style:preserve-3d;
transform:rotateX(4deg);
filter:drop-shadow(0 50px 80px rgba(0,0,0,.85));
}

.book-cover{
position:absolute;inset:0;
border-radius:4px 20px 20px 4px;
background:linear-gradient(135deg,var(–cover) 0%,#9c3810 55%,var(–spine) 100%);
z-index:0;
}
.book-cover::before{
content:’’;position:absolute;left:0;top:0;bottom:0;width:32px;
background:var(–spine);border-radius:4px 0 0 4px;
box-shadow:inset -6px 0 12px rgba(0,0,0,.55);
}
.book-cover::after{
content:’’;position:absolute;inset:14px 14px 14px 42px;
border:2px solid rgba(232,200,112,.25);border-radius:0 12px 12px 0;
}

.pages-viewport{
position:absolute;inset:9px 9px 9px 32px;
border-radius:0 14px 14px 0;overflow:hidden;
background:var(–paper);
}
.pages-viewport::before{
content:’’;position:absolute;inset:0;pointer-events:none;z-index:0;
background-image:repeating-linear-gradient(
to bottom,transparent,transparent 31px,var(–line) 31px,var(–line) 32px);
opacity:.4;
}

.slides-track{
display:flex;height:100%;
transition:transform .72s cubic-bezier(.77,0,.175,1);
position:relative;z-index:1;
}

@keyframes pageIn{
from{transform:perspective(1400px) rotateY(-12deg) scale(.97);opacity:.5;}
to  {transform:perspective(1400px) rotateY(0) scale(1);opacity:1;}
}
.flip-anim{animation:pageIn .7s ease both;}

/* COVER SLIDE */
.cover-slide{
flex:0 0 100%;height:100%;
display:flex;flex-direction:column;align-items:center;justify-content:center;
text-align:center;padding:28px;
background:linear-gradient(155deg,#fdfaf2,#f0e4c4);
position:relative;overflow:hidden;
}
.cover-slide::before{
content:’’;position:absolute;inset:0;pointer-events:none;
background-image:repeating-linear-gradient(
to bottom,transparent,transparent 31px,
rgba(160,140,90,.25) 31px,rgba(160,140,90,.25) 32px);
}
.cover-emoji-ring{
position:relative;width:140px;height:140px;margin-bottom:14px;
}
.cover-emoji-ring .emoji-orbit{
position:absolute;inset:0;
animation:coverSpin 8s linear infinite;
transform-style:preserve-3d;
}
.cover-emoji-ring .e{
position:absolute;font-size:2rem;
transform-origin:70px 70px;
}
@keyframes coverSpin{from{transform:rotateZ(0);}to{transform:rotateZ(360deg);}}
.cover-center{
position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
font-size:3.2rem;animation:bounce 2.5s ease-in-out infinite;
}
@keyframes bounce{0%,100%{transform:scale(1);}50%{transform:scale(1.12);}}
.cover-h{
font-family:‘DM Serif Display’,serif;font-size:clamp(1.9rem,4.5vw,2.6rem);
color:var(–ink);line-height:1.15;position:relative;margin:6px 0 4px;
}
.cover-h span{color:var(–red);font-style:italic;}
.cover-sub{font-size:1rem;color:var(–faded);position:relative;margin-bottom:20px;}
.cover-btn{
position:relative;font-family:‘Caveat’,cursive;font-size:1.1rem;letter-spacing:.5px;
background:var(–red);color:#fff;border:none;padding:10px 34px;
border-radius:30px;cursor:pointer;
box-shadow:0 4px 18px rgba(184,50,50,.4);transition:transform .2s,box-shadow .2s;
}
.cover-btn:hover{transform:scale(1.07);box-shadow:0 6px 24px rgba(184,50,50,.5);}

/* RECIPE SLIDE */
.slide{
flex:0 0 100%;height:100%;
position:relative;overflow:hidden;
}

.inner-track{
display:flex;width:200%;height:100%;
transition:transform .55s cubic-bezier(.77,0,.175,1);
}
.inner-page{
width:50%;height:100%;
padding:22px 28px 16px 28px;
flex-shrink:0;
position:relative;
}

.tab-bar{
display:flex;gap:0;margin-bottom:14px;
border-bottom:2px solid var(–line);
}
.tab{
font-family:‘Caveat’,cursive;font-size:1rem;
padding:5px 18px;border:none;background:transparent;
color:var(–faded);cursor:pointer;border-bottom:3px solid transparent;
margin-bottom:-2px;transition:all .25s;letter-spacing:.3px;
}
.tab.active{color:var(–ink);font-weight:700;border-bottom-color:var(–red);}
.tab.active.teal {border-bottom-color:var(–teal);}
.tab.active.amber{border-bottom-color:var(–amber);}

.r-header{margin-bottom:8px;}
.cat-tag{
display:inline-block;font-size:.7rem;font-weight:700;
letter-spacing:2px;text-transform:uppercase;color:#fff;
background:var(–red);padding:2px 10px;border-radius:3px;margin-bottom:4px;
}
.cat-tag.teal {background:var(–teal);}
.cat-tag.amber{background:var(–amber);}
.r-title{
font-family:‘DM Serif Display’,serif;
font-size:clamp(1.4rem,3vw,1.9rem);color:var(–ink);line-height:1.1;
}
.r-sub{font-size:.92rem;color:var(–faded);margin-top:1px;}
.divider{border:none;border-top:2px dashed var(–line);margin:8px 0 10px;}
.meta-row{display:flex;gap:14px;font-size:.9rem;color:var(–faded);flex-wrap:wrap;}

/* INGREDIENTS FLOATING EMOJIS */
.ing-stage{
position:relative;
width:100%;
height:calc(100% - 130px);
overflow:hidden;
}

.ing-item{
position:absolute;
display:flex;flex-direction:column;align-items:center;
cursor:default;
transform-origin:center center;
animation:floatItem var(–dur,5s) var(–delay,0s) ease-in-out infinite alternate;
transition:transform .2s;
}
.ing-item:hover{z-index:99;}
.ing-item:hover .i-emoji{transform:scale(1.25) rotate(8deg);}

.i-emoji{
font-size:var(–sz,3rem);
display:block;
transition:transform .3s cubic-bezier(.34,1.56,.64,1);
filter:drop-shadow(0 6px 10px rgba(0,0,0,.18));
animation:spin3d var(–spd,6s) var(–delay,0s) linear infinite;
}
@keyframes spin3d{
0%  {transform:rotateY(0deg);}
100%{transform:rotateY(360deg);}
}
.ing-item:hover .i-emoji{animation-play-state:paused;}

.i-label{
font-family:‘Caveat’,cursive;font-size:.82rem;
color:var(–ink);text-align:center;line-height:1.2;
margin-top:2px;max-width:80px;
text-shadow:0 1px 3px rgba(255,255,255,.9);
}
.i-qty{font-size:.7rem;color:var(–faded);}

@keyframes floatItem{
from{transform:translateY(0px) rotate(var(–rot0,-3deg));}
to  {transform:translateY(var(–dy,-12px)) rotate(var(–rot1,3deg));}
}

.page-hint{
position:absolute;bottom:10px;right:18px;
font-family:‘Caveat’,cursive;font-size:.88rem;
color:var(–faded);display:flex;align-items:center;gap:5px;
cursor:pointer;transition:color .2s;
animation:pulse 2s ease-in-out infinite;
}
.page-hint:hover{color:var(–ink);}
@keyframes pulse{0%,100%{opacity:.6;}50%{opacity:1;}}

/* STEPS PAGE */
.steps-scroll{
overflow-y:auto;
height:calc(100% - 130px);
padding-right:6px;
scrollbar-width:thin;
scrollbar-color:var(–line) transparent;
}
.steps-scroll::-webkit-scrollbar{width:4px;}
.steps-scroll::-webkit-scrollbar-thumb{background:var(–line);border-radius:4px;}

.step-item{
display:flex;gap:14px;
padding:10px 0 10px;
border-bottom:1px solid rgba(200,185,150,.4);
align-items:flex-start;
}
.step-num{
flex-shrink:0;width:30px;height:30px;
background:var(–red);color:#fff;border-radius:50%;
font-family:‘DM Serif Display’,serif;font-size:.85rem;
display:flex;align-items:center;justify-content:center;
box-shadow:0 3px 8px rgba(184,50,50,.35);
margin-top:1px;
}
.step-num.teal {background:var(–teal);box-shadow:0 3px 8px rgba(26,122,101,.35);}
.step-num.amber{background:var(–amber);box-shadow:0 3px 8px rgba(196,120,32,.35);}

.step-body{flex:1;}
.step-title{
font-family:‘DM Serif Display’,serif;font-size:.95rem;
color:var(–ink);margin-bottom:2px;
}
.step-desc{
font-family:‘Cormorant Garamond’,serif;font-size:.95rem;
color:#4a3e28;line-height:1.55;
}

.note-box{
margin-top:12px;padding:9px 14px;
background:#f5edcf;border-left:3px solid var(–amber);
border-radius:0 6px 6px 0;
font-family:‘Caveat’,cursive;font-size:.9rem;color:var(–faded);
line-height:1.55;
}

/* LANG */
[data-lang]{display:none;}
.lang-es [data-lang=“es”]   {display:block;}
.lang-en [data-lang=“en”]   {display:block;}
.lang-es [data-lang=“es”].ib{display:inline-block;}
.lang-en [data-lang=“en”].ib{display:inline-block;}

/* NAV */
.nav-row{display:flex;align-items:center;gap:14px;margin-top:13px;}
.nav-btn{
width:46px;height:46px;border-radius:50%;
border:2px solid rgba(232,200,112,.28);
background:rgba(232,200,112,.07);color:var(–gold);
font-size:1.3rem;cursor:pointer;transition:all .25s;
display:flex;align-items:center;justify-content:center;
backdrop-filter:blur(4px);
}
.nav-btn:hover:not(:disabled){background:rgba(232,200,112,.2);border-color:var(–gold);transform:scale(1.1);}
.nav-btn:disabled{opacity:.2;cursor:default;}
.page-dots{display:flex;gap:7px;}
.dot{width:8px;height:8px;border-radius:50%;background:rgba(232,200,112,.2);transition:all .3s;cursor:pointer;}
.dot.active{background:var(–gold);transform:scale(1.4);}
</style>

</head>
