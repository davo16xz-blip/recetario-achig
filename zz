  ],
  [
    {e:'🍚',es:'Arroz',          en:'White rice',       qty:'1 taza', sz:'3.2rem', spd:'8s'},
    {e:'🥛',es:'Leche entera',   en:'Whole milk',       qty:'1 L',    sz:'3rem',   spd:'6s'},
    {e:'🍬',es:'Azúcar',         en:'Sugar',            qty:'¾ taza', sz:'2.6rem', spd:'7s'},
    {e:'🌿',es:'Canela',         en:'Cinnamon',         qty:'1 rama', sz:'2.8rem', spd:'9s'},
    {e:'🍋',es:'Limón',          en:'Lemon zest',       qty:'×1',     sz:'2.6rem', spd:'5.5s'},
  ],
  [
    {e:'🌺',es:'Flor jamaica',   en:'Hibiscus flowers', qty:'1 taza', sz:'3.4rem', spd:'7s'},
    {e:'💧',es:'Agua',           en:'Water',            qty:'1 L',    sz:'2.8rem', spd:'6s'},
    {e:'🍬',es:'Azúcar',         en:'Sugar',            qty:'¾ taza', sz:'2.6rem', spd:'8s'},
    {e:'🧊',es:'Hielo',          en:'Ice',              qty:'gusto',  sz:'3rem',   spd:'5s'},
    {e:'🍋',es:'Limón',          en:'Lime',             qty:'×2',     sz:'2.8rem', spd:'9s'},
  ],
];

let currentLang = 'es';
const innerPage = [0, 0, 0];

const POSITIONS = [
  [8,  10, -14,  -4,  5],
  [55, 6,  -10,   3, -4],
  [75, 35, -16,  -3,  6],
  [60, 65, -12,   5, -3],
  [25, 68, -10,  -5,  4],
  [5,  45, -14,   4, -5],
  [38, 30,  -8,  -2,  3],
];

function buildIngredients() {
  INGREDIENTS.forEach((list, ri) => {
    const stage = document.getElementById('ing' + ri);
    stage.innerHTML = '';
    list.forEach((item, i) => {
      const pos = POSITIONS[i] || POSITIONS[i % POSITIONS.length];
      const div = document.createElement('div');
      div.className = 'ing-item';
      div.style.cssText = `
        left:${pos[0]}%;top:${pos[1]}%;
        --sz:${item.sz};--spd:${item.spd};
        --dur:${3.5 + i * 0.7}s;
        --delay:${i * 0.4}s;
        --dy:${pos[2]}px;
        --rot0:${pos[3]}deg;--rot1:${pos[4]}deg;
      `;
      div.innerHTML = `
        <span class="i-emoji" style="font-size:${item.sz};animation-duration:${item.spd}">${item.e}</span>
        <span class="i-label">
          <span data-lang="es">${item.es}</span>
          <span data-lang="en">${item.en}</span>
        </span>
        <span class="i-qty">${item.qty}</span>`;
      stage.appendChild(div);
    });
  });
  applyLangToStages();
}

function applyLangToStages() {
  document.querySelectorAll('.i-label [data-lang]').forEach(el => {
    el.style.display = (el.dataset.lang === currentLang) ? 'block' : 'none';
  });
}

function innerGoTo(recipeIdx, pageIdx, clickedTab) {
  innerPage[recipeIdx] = pageIdx;
  const track = document.getElementById('it' + recipeIdx);
  track.style.transform = `translateX(-${pageIdx * 50}%)`;
  const slide = document.getElementById('s' + recipeIdx);
  const allTabs = slide.querySelectorAll('.tab');
  allTabs.forEach((t, i) => {
    t.classList.toggle('active', (i % 2) === pageIdx);
  });
}

const TOTAL = 4;
let cur = 0;
const track   = document.getElementById('track');
const prevBtn = document.getElementById('prevBtn');
const nextBtn = document.getElementById('nextBtn');
const dotsEl  = document.getElementById('dots');

for (let i = 0; i < TOTAL; i++) {
  const d = document.createElement('div');
  d.className = 'dot' + (i === 0 ? ' active' : '');
  d.onclick = () => goTo(i);
  dotsEl.appendChild(d);
}

function goTo(idx) {
  cur = Math.max(0, Math.min(idx, TOTAL - 1));
  track.style.transform = `translateX(-${cur * 100}%)`;
  const slides = track.children;
  for (const s of slides) s.classList.remove('flip-anim');
  void slides[cur].offsetWidth;
  slides[cur].classList.add('flip-anim');
  prevBtn.disabled = cur === 0;
  nextBtn.disabled = cur === TOTAL - 1;
  document.querySelectorAll('.dot').forEach((d, i) => d.classList.toggle('active', i === cur));
}
function navigate(dir) { goTo(cur + dir); }

let sx = null;
const scene = document.getElementById('scene');
scene.addEventListener('touchstart', e => { sx = e.touches[0].clientX; }, {passive:true});
scene.addEventListener('touchend',   e => {
  if (sx===null) return;
  const dx = e.changedTouches[0].clientX - sx;
  if (Math.abs(dx) > 38) navigate(dx < 0 ? 1 : -1);
  sx = null;
});
let mx = null;
scene.addEventListener('mousedown', e => { mx = e.clientX; });
window.addEventListener('mouseup',  e => {
  if (mx===null) return;
  const dx = e.clientX - mx;
  if (Math.abs(dx) > 38) navigate(dx < 0 ? 1 : -1);
  mx = null;
});
document.addEventListener('keydown', e => {
  if (e.key==='ArrowRight') navigate(1);
  if (e.key==='ArrowLeft')  navigate(-1);
});

function setLang(lang) {
  currentLang = lang;
  document.body.className = 'lang-' + lang;
  document.querySelectorAll('.lang-btn').forEach((b,i) => b.classList.toggle('active', (lang==='es'?0:1)===i));
  applyLangToStages();
}

buildIngredients();
goTo(0);
</script>

